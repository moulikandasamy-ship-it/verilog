module diamond_pattern;
    integer i,j;

    task print_diamond;
    begin
        for(i=1;i<=5;i=i+1) begin
            for(j=1;j<=i;j=j+1)
                $write("%0d",i);
            $write("\n");
        end
        for(i=4;i>=1;i=i-1) begin
            for(j=1;j<=i;j=j+1)
                $write("%0d",i);
            $write("\n");
        end
    end
    endtask

endmodule
