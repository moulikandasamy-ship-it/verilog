module tb_clk_100hz;

    reg clk;
    reg rst;
    wire clk_out;

    clk_100hz uut (
        .clk(clk),
        .rst(rst),
        .clk_out(clk_out)
    );

    always #10 clk = ~clk;

    initial begin
        $dumpfile("clk_100hz.vcd");
        $dumpvars(0, tb_clk_100hz);

        $monitor("Time=%0t | rst=%0b clk_out=%0b", $time, rst, clk_out);

        clk = 0;
        rst = 1;

        #50  rst = 0;     
        #10000000 $finish;  
    end

endmodule
