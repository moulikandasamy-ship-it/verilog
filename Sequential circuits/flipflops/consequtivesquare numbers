module square_odd_series (
    input  clk,
    input  rst,
    output reg [15:0] square
);

reg [7:0] count;
reg [15:0] odd;

always @(posedge clk or posedge rst) begin
    if (rst) begin
        count  <= 1;
        odd    <= 1;
        square <= 0;
    end
    else begin
        square <= square + odd; 
        odd    <= odd + 2;       
        count  <= count + 1;
    end
end

endmodule
