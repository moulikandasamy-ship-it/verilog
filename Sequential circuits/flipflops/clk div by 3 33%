module clk_div3_33 (
    input clk,
    input rst,
    output reg clk_out
);

reg [1:0] count;

always @(posedge clk or posedge rst)
begin
    if(rst)
    begin
        count <= 0;
        clk_out <= 0;
    end
    else
    begin
        if(count == 2)
            count <= 0;
        else
            count <= count + 1;

        if(count == 0)
            clk_out <= 1;
        else
            clk_out <= 0;
    end
end

endmodule
