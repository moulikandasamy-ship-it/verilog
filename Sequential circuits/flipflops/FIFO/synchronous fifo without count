module fifo(
    input clk,
    input write_en,
    input read_en,
    input [7:0] din,
    input rst,
    output reg [7:0] dout,
    output full,
    output empty
);

reg [7:0] mem [7:0];
reg [2:0] write_ptr;
reg [2:0] read_ptr;


always @(posedge clk or posedge rst)
begin
    if(rst)
        write_ptr <= 0;
    else if(write_en && !full)
    begin
        mem[write_ptr] <= din;
        write_ptr <= write_ptr + 1;
    end
end

always @(posedge clk or posedge rst)
begin
    if(rst)
        read_ptr <= 0;
    else if(read_en && !empty)
    begin
        dout <= mem[read_ptr];
        read_ptr <= read_ptr + 1;
    end
end


assign full  = (write_ptr + 1 == read_ptr);
assign empty = (write_ptr == read_ptr);

endmodule
         
