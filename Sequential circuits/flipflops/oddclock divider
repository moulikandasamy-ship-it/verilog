module odd_divider_by3_simple (
    input  wire clk,
    input  wire rst,
    output reg  clk_div3
);

reg [1:0] cnt;

always @(posedge clk or posedge rst) begin
    if (rst) begin
        cnt      <= 2'd0;
        clk_div3 <= 1'b0;
    end else begin
        if (cnt == 2'd2)
            cnt <= 2'd0;
        else
            cnt <= cnt + 1'b1;

        if (cnt == 2'd0 || cnt == 2'd2)
            clk_div3 <= ~clk_div3;
    end
end

endmodule
