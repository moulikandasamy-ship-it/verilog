module uart_tx(
  input clk,
  input rst,
  input [7:0] din,
  input tx_start,
  output reg txout
);

reg [7:0] datareg;
reg [1:0] nextstate, state;
reg [2:0] count;

parameter idle  = 2'b00,
          start = 2'b01,
          data  = 2'b10,
          stop  = 2'b11;

always @(posedge clk or posedge rst)
begin
  if(rst)
  begin
    state   <= idle;
    txout   <= 1'b1;
    count   <= 3'b0;
    datareg <= 8'b0;
  end
  else
    state <= nextstate;
end


always @(*)
begin
  case(state)

    idle:
    begin
      txout = 1'b1;
      count = 3'b0;
      datareg = 8'b0;
      if(tx_start)
        nextstate = start;
      else
        nextstate = idle;
    end

    start:
    begin
      txout = 1'b0;
      datareg = din;
      count = 3'b0;
      nextstate = data;
    end

    data:
    begin
      txout = datareg[count];
      count = count + 1;
      if(count == 3'd7)
        nextstate = stop;
      else
        nextstate = data;
    end

    stop:
    begin
      txout = 1'b1;
      nextstate = idle;
    end

  endcase
end

endmodule
